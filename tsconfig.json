{
  "compilerOptions": {
    "target": "ESNext",
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "resolveJsonModule": true,
    "paths": {
      "*": [
        "./src/*"
      ]
    },
  },
  "exclude": [
    "node_modules"
  ]
}
